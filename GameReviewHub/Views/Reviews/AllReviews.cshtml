@model List<GameReviewHub.ViewModels.Review.ReviewListItemViewModel>

@{
    ViewData["Title"] = "All Reviews";
}

@if (TempData["VoteMessage"] != null)
{
    <div id="voteAlert" class="alert alert-warning">
        @TempData["VoteMessage"]
    </div>
}

<h2 class="mb-4">All Reviews</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No reviews yet.</div>
}
else
{
    @foreach (var review in Model)
    {
        <partial name="_ReviewCardPartial"
                 model="review"
                 view-data='new ViewDataDictionary(ViewData) { ["ShowGameTitle"] = true }' />
    }
}

@section Scripts {
    <script>
        const alert = document.getElementById("voteAlert");

        if (alert) {
            setTimeout(() => {
                alert.style.transition = "opacity 0.5s";
                alert.style.opacity = "0";

                setTimeout(() => alert.remove(), 500);
            }, 3000);
        }
    </script>
}