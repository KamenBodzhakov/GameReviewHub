@model GameReviewHub.ViewModels.Review.GameReviewsViewModel

@{
    ViewData["Title"] = $"{Model.GameTitle} - Reviews";
}

@if (TempData["VoteMessage"] != null)
{
    <div id="voteAlert" class="alert alert-warning">
        @TempData["VoteMessage"]
    </div>
}

<h2 class="mb-4">@Model.GameTitle</h2>

@if (!Model.Reviews.Any())
{
    <div class="alert alert-info">
        There are no reviews for this game yet.
    </div>
}
else
{
    @foreach (var review in Model.Reviews)
    {
        <partial name="_ReviewCardPartial"
                 model="review"
                 view-data='new ViewDataDictionary(ViewData) { ["ShowGameTitle"] = false }' />
    }
}

<div class="d-flex justify-content-between align-items-center mt-4">
    <a class="btn btn-outline-primary"
       asp-controller="Games"
       asp-action="Index">
        ← Back to Games List
    </a>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-success"
           asp-controller="Reviews"
           asp-action="CreateReview"
           asp-route-gameId="@Model.GameId">
            + Add Review
        </a>
    }
    else
    {
        <div class="d-flex align-items-center gap-3">
            <span class="fw-bold text-danger">
                🔒 Log in to leave a review.
            </span>

            <a class="btn btn-warning fw-semibold px-3"
               asp-area="Identity"
               asp-page="/Account/Login"
               asp-route-returnUrl="@Url.Action("ByGame", "Reviews", new { gameId = Model.GameId })">
                Login
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        const alert = document.getElementById("voteAlert");

        if (alert) {
            setTimeout(() => {
                alert.style.transition = "opacity 0.5s";
                alert.style.opacity = "0";

                setTimeout(() => alert.remove(), 500);
            }, 3000);
        }
    </script>
}