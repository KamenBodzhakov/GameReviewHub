@model GameReviewHub.ViewModels.Review.ReviewListItemViewModel
@using System.Security.Claims

@{
    string? currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool showGameTitle = ViewData["ShowGameTitle"] as bool? ?? false;
}

<div class="card mb-3 shadow-sm">
    <div class="card-body d-flex flex-column">

        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h5 class="mb-0">@Model.ReviewTitle</h5>

                @if (showGameTitle)
                {
                    <div class="text-muted">
                        Game:
                        <a asp-controller="Reviews"
                           asp-action="ByGame"
                           asp-route-gameId="@Model.GameId">
                            @Model.GameTitle
                        </a>
                    </div>
                }
            </div>

            <span class="badge bg-success fs-6">
                @Model.Rating / 10
            </span>
        </div>

        <small class="text-muted">
            Posted by <strong>@Model.AuthorUserName</strong>
            on @Model.CreatedOn.ToString("yyyy-MM-dd")
        </small>

        <p class="mt-3 mb-3" style="white-space: pre-line;">
            @Model.Body
        </p>

        <div class="mt-2 d-flex justify-content-between align-items-center">
            <form asp-controller="ReviewVotes"
                  asp-action="Vote"
                  method="post"
                  class="m-0">

                <input type="hidden" name="reviewId" value="@Model.ReviewId" />
                <input type="hidden" name="gameId" value="@Model.GameId" />
                <input type="hidden" name="isUpvote" value="true" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                <button type="submit" class="btn btn-sm btn-outline-success">
                    👍 @Model.VoteCount
                </button>
            </form>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-sm btn-outline-secondary"
                   asp-controller="ReviewComments"
                   asp-action="CreateReviewComment"
                   asp-route-reviewId="@Model.ReviewId"
                   asp-route-gameId="@Model.GameId">
                    Add Comment
                </a>
            }
        </div>

        @if (Model.Comments.Any())
        {
            <div class="mt-3 border-top pt-2">
                <strong>Comments</strong>

                @foreach (var comment in Model.Comments)
                {
                    <div class="mt-2 p-2 border rounded bg-light">
                        <small class="text-muted">
                            <strong>@comment.AuthorUserName</strong>
                            on @comment.CreatedOn.ToString("yyyy-MM-dd")
                        </small>

                        <div>
                            @comment.Body
                        </div>
                    </div>
                }
            </div>
        }

        <div class="mt-auto text-end pt-3">
            @if (User.Identity?.IsAuthenticated == true && currentUserId == Model.AuthorUserId)
            {
                <a class="btn btn-outline-primary me-2"
                   asp-controller="Reviews"
                   asp-action="EditReview"
                   asp-route-gameId="@Model.GameId"
                   asp-route-reviewId="@Model.ReviewId">
                    Edit
                </a>

                <a class="btn btn-outline-danger"
                   asp-controller="Reviews"
                   asp-action="DeleteReview"
                   asp-route-gameId="@Model.GameId"
                   asp-route-reviewId="@Model.ReviewId">
                    Delete
                </a>
            }
        </div>

    </div>
</div>