@model GameReviewHub.ViewModels.ReviewComment.CreateReviewCommentViewModel

@{
    ViewData["Title"] = "Add Comment";
}

<h2 class="mb-4">Add Comment</h2>

<form asp-action="CreateReviewComment" method="post">
    <input type="hidden" asp-for="ReviewId" />
    <input type="hidden" asp-for="GameId" />

    <div class="mb-3">
        <label asp-for="Input.Body" class="form-label"></label>
        <textarea asp-for="Input.Body" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Input.Body" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Post Comment</button>

    <a asp-controller="Reviews"
       asp-action="ByGame"
       asp-route-gameId="@Model.GameId"
       class="btn btn-secondary">
        Cancel
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}